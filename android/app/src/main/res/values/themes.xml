<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Hitta" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/background</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/background</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/foreground</item>
        <item name="colorOnSurface">@color/foreground</item>

        <!-- Error -->
        <item name="colorError">@color/danger</item>
        <item name="colorOnError">@color/foreground</item>

        <!-- Status / Navigation bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text input outline color -->
        <item name="colorControlNormal">@color/foreground</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlHighlight">@color/accent</item>
    </style>

</resources>
