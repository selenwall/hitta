<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewViewDetect"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/scrollDetectObjects"
        app:layout_constraintVertical_weight="1" />

    <!-- Overlay for bounding boxes -->
    <com.hitta.app.camera.OverlayView
        android:id="@+id/overlayDetect"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewViewDetect"
        app:layout_constraintStart_toStartOf="@id/previewViewDetect"
        app:layout_constraintEnd_toEndOf="@id/previewViewDetect"
        app:layout_constraintBottom_toBottomOf="@id/previewViewDetect" />

    <!-- Detect instructions overlay -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/detect_instructions"
        android:textColor="@color/foreground"
        android:textSize="14sp"
        android:background="#99000000"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/previewViewDetect"
        app:layout_constraintStart_toStartOf="@id/previewViewDetect"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp" />

    <!-- Bottom panel -->
    <ScrollView
        android:id="@+id/scrollDetectObjects"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        app:layout_constraintTop_toBottomOf="@id/previewViewDetect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnCancelDetect"
        app:layout_constraintVertical_weight="1">

        <LinearLayout
            android:id="@+id/detectedObjectsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />

    </ScrollView>

    <Button
        android:id="@+id/btnCancelDetect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_cancel"
        android:backgroundTint="@color/danger"
        android:textColor="@color/foreground"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
