<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewViewPlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/scrollPlayObjects"
        app:layout_constraintVertical_weight="1" />

    <!-- Overlay for bounding boxes -->
    <com.hitta.app.camera.OverlayView
        android:id="@+id/overlayPlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewViewPlay"
        app:layout_constraintStart_toStartOf="@id/previewViewPlay"
        app:layout_constraintEnd_toEndOf="@id/previewViewPlay"
        app:layout_constraintBottom_toBottomOf="@id/previewViewPlay" />

    <!-- HUD overlay on camera -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#99000000"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/previewViewPlay"
        app:layout_constraintStart_toStartOf="@id/previewViewPlay"
        app:layout_constraintEnd_toEndOf="@id/previewViewPlay">

        <TextView
            android:id="@+id/tvScoresPlay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/foreground"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2:00"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Target label banner -->
    <TextView
        android:id="@+id/tvTargetLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/background"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@color/accent"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="@id/previewViewPlay"
        app:layout_constraintStart_toStartOf="@id/previewViewPlay"
        app:layout_constraintEnd_toEndOf="@id/previewViewPlay" />

    <!-- Bottom panel: detected objects -->
    <ScrollView
        android:id="@+id/scrollPlayObjects"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        app:layout_constraintTop_toBottomOf="@id/previewViewPlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnGiveUp"
        app:layout_constraintVertical_weight="1">

        <LinearLayout
            android:id="@+id/detectedObjectsPlayContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />

    </ScrollView>

    <Button
        android:id="@+id/btnGiveUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_give_up"
        android:backgroundTint="@color/danger"
        android:textColor="@color/foreground"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
